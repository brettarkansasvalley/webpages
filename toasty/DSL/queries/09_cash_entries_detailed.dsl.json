{
  "_description": "Detailed cash entries with employee information",
  "_csv_source": "cashmgmt_v1_entries_20260130.json",
  "query": {
    "from": {
      "source_file": "cashmgmt_v1_entries_20260130.json",
      "alias": "ce"
    },
    "joins": [
      {
        "source": {
          "source_file": "labor_v1_employees.json",
          "alias": "emp"
        },
        "on": {
          "left": "ce.employee1.guid",
          "right": "emp.guid"
        },
        "join_type": "left",
        "skip_nulls": true
      }
    ],
    "select": [
      {"expr": "ce.guid", "alias": "entry_guid"},
      {"expr": "ce.date", "alias": "entry_date"},
      {"expr": "ce.type", "alias": "type"},
      {"expr": "ce.reason", "alias": "reason"},
      {"expr": "ce.amount", "alias": "amount"},
      {"expr": "ce.employee1.guid", "alias": "employee_guid"},
      {"expr": "emp.firstName", "alias": "employee_first_name"},
      {"expr": "emp.lastName", "alias": "employee_last_name"},
      {"expr": "ce.approverOrShiftReviewSubject.guid", "alias": "approver_guid"}
    ],
    "order_by": [
      {"field": "ce.date", "direction": "desc"}
    ]
  }
}
