@app.route('/api/buckets', methods=['GET'])
def get_buckets():
    """Get all unique buckets from worker_assignments."""
    conn = get_db()
    cursor = conn.cursor()
    cursor.execute("SELECT DISTINCT bucket FROM worker_assignments ORDER BY bucket")
    db_buckets = [row['bucket'] for row in cursor.fetchall()]
    
    # Map bucket IDs to display names
    buckets = []
    for bucket_id in db_buckets:
        buckets.append({
            "id": bucket_id,
            "name": bucket_id_to_display(bucket_id)
        })
    
    # If no buckets in DB, return defaults (Toast location buckets)
    if not buckets:
        buckets = [
            {"id": "am_bar", "name": "AM Bar"},
            {"id": "sunset", "name": "Sunset Bar"},
            {"id": "westwing", "name": "West Wing"},
            {"id": "eastwing", "name": "East Wing"}
        ]
    
    conn.close()
    return jsonify(buckets)

def parse_toast_datetime(dt_str: str) -> Optional[datetime]:
    """Parse Toast datetime string to datetime object.
    Handles formats like: 2025-12-30T15:37:30.780+0000
    """
    if not dt_str:
        return None
    try:
        # Handle +0000 format (convert to +00:00 for fromisoformat)
        if dt_str.endswith('+0000'):
            dt_str = dt_str[:-5] + '+00:00'
        elif dt_str.endswith('-0000'):
            dt_str = dt_str[:-5] + '-00:00'
        elif '+00:00' not in dt_str and '-00:00' not in dt_str:
            # Handle Z suffix
            dt_str = dt_str.replace('Z', '+00:00')
        return datetime.fromisoformat(dt_str)
    except Exception:
        return None


def calculate_tips_from_orders(worker_name: str, date_str: str) -> Dict:
    """Calculate tips from Toast orders for a specific worker on a date.
    
    Returns dict with:
    - cash_tips: Tips from cash payments
    - non_cash_tips: Tips from credit/card payments  
    - gratuity: Auto-gratuity (if available)
    - net_sales: Total sales attributed to worker
    - tips_by_bucket: Breakdown by location bucket
    """
    result = {
        "cash_tips": 0.0,
        "non_cash_tips": 0.0,
        "gratuity": 0.0,
        "net_sales": 0.0,
        "tips_by_bucket": {}
    }
    
    # Get employee GUID from JAQ
    emp_guid = get_employee_guid_for_worker(worker_name)
    if not emp_guid:
        print(f"No employee GUID found for {worker_name}")
        return result
    
    # Convert date to order file format
    date_part = date_str.replace("-", "")
    order_file = JSON_DIR / f"orders_full_{date_part}.json"
    
    if not order_file.exists():
        print(f"Order file not found: {order_file}")
        return result
    
    try:
        with open(order_file, 'r') as f:
            orders = json.load(f)
        
        print(f"Processing {len(orders)} orders for {worker_name} on {date_str}")
        
        # Get worker's shifts to determine time ranges and buckets
        shifts = get_worker_shifts_for_date(worker_name, date_str)
        if not shifts:
            print(f"No shifts found for {worker_name} on {date_str}")
            return result
        
        print(f"Found {len(shifts)} shifts")
        
        # Build time ranges for each shift
        shift_ranges = []
        for shift in shifts:
            start = shift.get('start_time', '')
            end = shift.get('end_time', '')
            bucket = job_title_to_bucket_id(shift.get('job_title', ''))
            start_dt = parse_toast_datetime(start)
            end_dt = parse_toast_datetime(end)
            if start_dt and end_dt:
                shift_ranges.append({
                    'start': start_dt,
                    'end': end_dt,
                    'bucket': bucket
                })
                print(f"  Shift: {bucket} - {start_dt} to {end_dt}")
        
        # Build employee alias set for robust matching (guid)
        emp_aliases = {emp_guid}
        
        # Process each order
        for order in orders:
            checks = order.get('checks', [])
            for check in checks:
                if check.get('voided') or check.get('deleted'):
                    continue
                
                # Get check timestamp
                check_time_str = check.get('paidDate') or check.get('closedDate') or check.get('openedDate')
                check_time = parse_toast_datetime(check_time_str)
                if not check_time:
                    continue
                
                # Find which shift this check belongs to
                matched_bucket = None
                for shift_range in shift_ranges:
                    if shift_range['start'] <= check_time <= shift_range['end']:
                        matched_bucket = shift_range['bucket']
                        break
                
                if not matched_bucket:
                    continue
                
                # Check if this worker was the server on any payment in this check
                has_emp_payment = False
                check_cash_tips = 0
                check_credit_tips = 0
                
                for payment in check.get('payments', []):
                    srv_obj = payment.get('server', {}) or {}
                    psrv_ids = [
                        srv_obj.get('guid', ''),
                        srv_obj.get('id', ''),
                        srv_obj.get('v2EmployeeGuid', ''),
                    ]
                    
                    # Check if any server ID matches employee GUID
                    matched_emp = False
                    for sid in psrv_ids:
                        if sid and sid in emp_aliases:
                            matched_emp = True
                            break
                    
                    if matched_emp:
                        has_emp_payment = True
                        tip = payment.get('tipAmount', 0) or 0
                        payment_type = payment.get('type', '').upper()
                        
                        if payment_type == 'CASH':
                            check_cash_tips += tip
                        else:
                            check_credit_tips += tip
                
                # Only add to totals if employee was the server
                if has_emp_payment:
                    # Use 'amount' (net after discounts) like the original app, not 'totalAmount' (gross)
                    # Also check for gift card purchases and exclude them
                    check_amount = check.get('amount') or check.get('total') or check.get('net') or check.get('subtotal') or 0.0
                    check_amount = float(check_amount)
                    
                    # Check if this check has gift card purchases - exclude them from net sales
                    gift_card_total = 0.0
                    for selection in check.get('selections', []):
                        item_name = (selection.get('displayName', '') or selection.get('itemName', '')).lower()
                        if 'gift card' in item_name or 'giftcard' in item_name:
                            gift_card_total += float(selection.get('price', 0) or 0)
                    
                    # Subtract gift card sales from net sales (like original app)
                    check_net_sales = check_amount - gift_card_total
                    
                    # Add to totals
                    result['cash_tips'] += check_cash_tips
                    result['non_cash_tips'] += check_credit_tips
                    result['net_sales'] += check_net_sales
                    
                    # Add to bucket breakdown
                    if matched_bucket:
                        if matched_bucket not in result['tips_by_bucket']:
                            result['tips_by_bucket'][matched_bucket] = {
                                'cash_tips': 0,
                                'non_cash_tips': 0,
                                'net_sales': 0
                            }
                        result['tips_by_bucket'][matched_bucket]['cash_tips'] += check_cash_tips
                        result['tips_by_bucket'][matched_bucket]['non_cash_tips'] += check_credit_tips
                        result['tips_by_bucket'][matched_bucket]['net_sales'] += check_net_sales
        
        return result
        
    except Exception as e:
        print(f"Error calculating tips: {e}")
        return result


# ====================
# SERVER TIPS API
# ====================

@app.route('/api/server-tips', methods=['GET'])
def get_server_tips():
    """Get server tips for a specific worker/date/bucket."""
    worker = request.args.get('worker')
    date = request.args.get('date')
    bucket = request.args.get('bucket', '')
    
    if not worker or not date:
        return jsonify({"error": "Worker and date required"}), 400
    
    conn = get_db()
    cursor = conn.cursor()
    
    # Get existing tips record
    cursor.execute("""
        SELECT * FROM servers 
        WHERE worker_name = ? AND business_date = ? AND bucket = ?
        ORDER BY id DESC LIMIT 1
    """, (worker, date, bucket))
    
    row = cursor.fetchone()
    
    # Get suggested buckets from shifts
    suggested_buckets = get_suggested_buckets_for_worker(worker, date)
    
    # Calculate tips from Toast orders
    calculated_tips = calculate_tips_from_orders(worker, date)
    
    # If a specific bucket is selected, filter the results to show only that bucket's data
    if bucket and bucket in calculated_tips.get('tips_by_bucket', {}):
        bucket_data = calculated_tips['tips_by_bucket'][bucket]
        filtered_tips = {
            "cash_tips": bucket_data['cash_tips'],
            "non_cash_tips": bucket_data['non_cash_tips'],
            "gratuity": 0.0,  # Gratuity not tracked per bucket currently
            "net_sales": bucket_data['net_sales'],
            "tips_by_bucket": {bucket: bucket_data}
        }
        calculated_tips = filtered_tips
    
    conn.close()
    
    result = {
        "suggested_buckets": suggested_buckets,
        "calculated_tips": calculated_tips,
        "existing_record": None
    }
    
    if row:
        result["existing_record"] = {
            "id": row['id'],
            "server": row['worker_name'],
            "date": row['business_date'],
            "bucket": row['bucket'],
            "cash_tips": row['cash_tips'],
            "non_cash_tips": row['credit_tips'],
            "gratuity": row['gratuity'],
            "net_sales": row['net_sales'],
            "sum_tips_for_payout": row['cash_tips'] + row['credit_tips']
        }
    
    return jsonify(result)

@app.route('/api/server-tips', methods=['POST'])
def save_server_tips():
    """Save server tips."""
    data = request.json
    
    conn = get_db()
    cursor = conn.cursor()
    
    # Calculate sum for payout
    sum_tips = (
        float(data.get('bar_tips', 0)) +
        float(data.get('busser_tips', 0)) +
        float(data.get('expo_tips', 0)) +
        float(data.get('runner_tips', 0))
    )
    
    cursor.execute("""
        INSERT INTO servers 
        (business_date, worker_name, bucket, cash_tips, credit_tips, gratuity, net_sales, bar_tips, busser_tips, expo_tips, runner_tips)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        data.get('date'),
        data.get('worker'),
        data.get('bucket', ''),
        data.get('cash_tips', 0),
        data.get('credit_tips', 0),
        data.get('gratuity', 0),
        data.get('net_sales', 0),
        data.get('bar_tips', 0),
        data.get('busser_tips', 0),
        data.get('expo_tips', 0),
        data.get('runner_tips', 0)
    ))
    
    conn.commit()
    conn.close()
    
    return jsonify({"success": True, "id": cursor.lastrowid})

