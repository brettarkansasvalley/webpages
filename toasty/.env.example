# Copy this file to .env and fill in real values. .env is gitignored.

# Toast API credentials (used by start.sh, webapp/start_api.sh, get_toast.py,
# fetch_date_range.py, toast_30d_report.py, webapp/api.py)
TOAST_CLIENT_ID=your-toast-client-id
TOAST_CLIENT_SECRET=your-toast-client-secret
TOAST_RESTAURANT_GUID=your-restaurant-guid
TOAST_API_HOST=https://ws-api.toasttab.com

# Gmail app password for jbhooks report emails
GMAIL_SENDER_PASSWORD=your-gmail-app-password
