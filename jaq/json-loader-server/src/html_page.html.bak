<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JAQ JSON Loader & Query Tool</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.17.1/cdn/themes/light.css">
    <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.17.1/cdn/shoelace.js"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            max-width: 1600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: #f0f0f0;
            padding: 15px;
            border-radius: 8px;
            min-width: 150px;
        }
        .stat-card h3 {
            margin: 0 0 5px 0;
            font-size: 14px;
            color: #666;
        }
        .stat-card p {
            margin: 0;
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }
        .query-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        .input-group {
            margin-bottom: 15px;
        }
        .input-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
        }
        .results-section {
            margin-top: 20px;
        }
        .json-display {
            background: #f8f8f8;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 15px;
            font-family: 'Courier New', monospace;
            font-size: 13px;
            max-height: 600px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        .file-info {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
            padding: 10px;
            background: #e8f4f8;
            border-radius: 4px;
        }
        .object-item {
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-bottom: 15px;
            overflow: hidden;
        }
        .object-header {
            background: #f5f5f5;
            padding: 10px;
            border-bottom: 1px solid #ddd;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .object-content {
            padding: 15px;
        }
        .error-message {
            background: #ffebee;
            color: #c62828;
            padding: 10px;
            border-radius: 4px;
            margin: 10px 0;
        }
        .success-message {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 10px;
            border-radius: 4px;
            margin: 10px 0;
        }
        sl-card {
            margin-bottom: 20px;
            display: block;
        }
        
        /* Query Builder Styles */
        .query-builder {
            display: grid;
            gap: 20px;
        }
        .query-section-title {
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .query-editor {
            font-family: 'Courier New', monospace;
            font-size: 13px;
            min-height: 200px;
        }
        .join-builder {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
        }
        .field-row {
            display: flex;
            gap: 10px;
            align-items: end;
            margin-bottom: 10px;
        }
        .field-row sl-input, .field-row sl-select {
            flex: 1;
        }
        .remove-btn {
            color: #dc3545;
            cursor: pointer;
        }
        
        /* Resizable Table Styles */
        .table-container {
            overflow-x: auto;
            resize: both;
            min-height: 200px;
            max-height: 800px;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: white;
        }
        .result-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        .result-table th {
            background: #f5f5f5;
            padding: 12px;
            text-align: left;
            font-weight: 600;
            border-bottom: 2px solid #ddd;
            position: sticky;
            top: 0;
            white-space: nowrap;
        }
        .result-table td {
            padding: 10px 12px;
            border-bottom: 1px solid #eee;
            max-width: 300px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .result-table tr:hover {
            background: #f8f9fa;
        }
        .result-table td:hover {
            overflow: visible;
            white-space: normal;
            word-break: break-word;
        }
        .null-value {
            color: #999;
            font-style: italic;
        }
        
        /* Tab-like navigation */
        .tab-nav {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 2px solid #ddd;
            padding-bottom: 10px;
        }
        .tab-btn {
            padding: 10px 20px;
            background: #f0f0f0;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }
        .tab-btn.active {
            background: #007bff;
            color: white;
        }
        .tab-panel {
            display: none;
        }
        .tab-panel.active {
            display: block;
        }

        /* Saved Queries Styles */
        .saved-query-item {
            background: #f8f9fa;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .saved-query-info {
            flex: 1;
        }
        .saved-query-name {
            font-weight: 600;
            font-size: 16px;
            margin-bottom: 5px;
        }
        .saved-query-desc {
            color: #666;
            font-size: 13px;
        }
        .saved-query-actions {
            display: flex;
            gap: 10px;
        }
        .saved-query-form {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .export-section {
            background: #f0f8ff;
            padding: 15px;
            border-radius: 8px;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🔍 JAQ JSON Loader & Query Tool</h1>
        <sl-button variant="primary" size="large" onclick="loadJsonFiles()">
            <sl-icon slot="prefix" name="upload"></sl-icon>
            Load JSON Files
        </sl-button>
    </div>

    <div id="loadResult"></div>

    <div class="stats">
        <div class="stat-card">
            <h3>Total Objects</h3>
            <p id="totalObjects">-</p>
        </div>
        <div class="stat-card">
            <h3>Files Loaded</h3>
            <p id="totalFiles">-</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <div class="tab-nav">
        <button class="tab-btn active" onclick="showTab('simple')">Simple Query</button>
        <button class="tab-btn" onclick="showTab('advanced')">Advanced Join Query</button>
        <button class="tab-btn" onclick="showTab('saved')">Saved Queries</button>
    </div>

    <!-- Simple Query Panel -->
    <div id="simple-panel" class="tab-panel active">
        <sl-card>
            <div slot="header">
                <strong>Simple Query Builder</strong>
            </div>
            <div class="query-section">
                <div>
                    <div class="input-group">
                        <label for="filter">JAQ Filter (optional):</label>
                        <sl-input id="filter" placeholder="e.g., .title | contains(&quot;feather&quot;)" size="medium"></sl-input>
                    </div>
                    <div class="input-group">
                        <label for="sourceFile">Source File (optional):</label>
                        <sl-select id="sourceFile" placeholder="Select a file" size="medium" clearable>
                            <sl-option value="">All Files</sl-option>
                        </sl-select>
                    </div>
                    <div class="input-group">
                        <label for="limit">Limit (optional):</label>
                        <sl-input id="limit" type="number" value="50" size="medium"></sl-input>
                    </div>
                    <sl-button variant="success" size="large" onclick="executeQuery()">
                        <sl-icon slot="prefix" name="search"></sl-icon>
                        Execute Query
                    </sl-button>
                </div>
                <div>
                    <label><strong>Example Filters:</strong></label>
                    <div style="margin-top: 10px;">
                        <sl-tag size="medium" onclick="setFilter('.title')" style="margin-right: 5px; cursor: pointer;">.title</sl-tag>
                        <sl-tag size="medium" onclick="setFilter('.title | contains(&quot;feather&quot;)')" style="margin-right: 5px; cursor: pointer;">.title | contains("feather")</sl-tag>
                        <sl-tag size="medium" onclick="setFilter('.gtin')" style="margin-right: 5px; cursor: pointer;">.gtin</sl-tag>
                        <sl-tag size="medium" onclick="setFilter('keys')" style="margin-right: 5px; cursor: pointer;">keys</sl-tag>
                    </div>
                    <div style="margin-top: 15px;">
                        <label><strong>Operations:</strong></label>
                        <div style="margin-top: 10px;">
                            <sl-tag size="medium" variant="neutral" style="margin-right: 5px;">.field - Get field</sl-tag>
                            <sl-tag size="medium" variant="neutral" style="margin-right: 5px;">.field[] - Explode array</sl-tag>
                            <sl-tag size="medium" variant="neutral" style="margin-right: 5px;">| func - Pipe to function</sl-tag>
                            <sl-tag size="medium" variant="neutral" style="margin-right: 5px;">[] - Flatten</sl-tag>
                        </div>
                    </div>
                </div>
            </div>
        </sl-card>
        
        <div class="results-section">
            <sl-card>
                <div slot="header">
                    <strong>Query Results</strong>
                    <span id="resultCount" style="margin-left: 10px; font-weight: normal;"></span>
                </div>
                <div id="results" class="json-display">
                    <p style="color: #666;">Execute a query to see results...</p>
                </div>
            </sl-card>
        </div>
    </div>

    <!-- Advanced Query Panel -->
    <div id="advanced-panel" class="tab-panel">
        <sl-card>
            <div slot="header">
                <strong>Advanced Join Query Builder</strong>
                <span style="margin-left: 10px; color: #666; font-size: 14px;">Join and transform JSON data across files</span>
            </div>
            
            <!-- Save Query Button -->
            <div style="margin-bottom: 20px;">
                <sl-button variant="neutral" size="small" onclick="showSaveQueryDialog()">
                    <sl-icon slot="prefix" name="bookmark"></sl-icon>
                    Save Current Query
                </sl-button>
            </div>
            
            <div class="query-builder">
                <!-- FROM Section -->
                <div>
                    <div class="query-section-title">
                        <sl-icon name="database"></sl-icon>
                        FROM (Primary Source)
                    </div>
                    <div class="field-row">
                        <sl-select id="dslFromSource" placeholder="Select source file" size="medium" style="flex: 2;">
                            <sl-option value="">Select a file...</sl-option>
                        </sl-select>
                        <sl-input id="dslFromAlias" placeholder="Alias (optional)" size="medium" value="primary" style="flex: 1;"></sl-input>
                    </div>
                </div>
                
                <!-- JOIN Section -->
                <div>
                    <div class="query-section-title">
                        <sl-icon name="link"></sl-icon>
                        JOIN (Optional)
                    </div>
                    <div id="joinsContainer">
                        <!-- Joins will be added here -->
                    </div>
                    <sl-button variant="neutral" size="small" onclick="addJoin()">
                        <sl-icon slot="prefix" name="plus"></sl-icon>
                        Add Join
                    </sl-button>
                </div>
                
                <!-- WHERE Section -->
                <div>
                    <div class="query-section-title">
                        <sl-icon name="funnel"></sl-icon>
                        WHERE (Filters)
                    </div>
                    <div id="whereContainer">
                        <!-- Filters will be added here -->
                    </div>
                    <sl-button variant="neutral" size="small" onclick="addWhere()">
                        <sl-icon slot="prefix" name="plus"></sl-icon>
                        Add Filter
                    </sl-button>
                </div>
                
                <!-- SELECT Section -->
                <div>
                    <div class="query-section-title">
                        <sl-icon name="list-columns"></sl-icon>
                        SELECT (Fields to Return)
                    </div>
                    <div id="selectContainer">
                        <!-- Select fields will be added here -->
                    </div>
                    <sl-button variant="neutral" size="small" onclick="addSelectField()">
                        <sl-icon slot="prefix" name="plus"></sl-icon>
                        Add Field
                    </sl-button>
                </div>
                
                <!-- Options -->
                <div>
                    <sl-checkbox id="dslFlatten">Flatten arrays (explode nested arrays into rows)</sl-checkbox>
                    <div style="margin-top: 10px;">
                        <sl-input id="dslLimit" type="number" value="100" label="Limit results" style="max-width: 200px;"></sl-input>
                    </div>
                </div>
                
                <!-- Query Preview -->
                <div>
                    <div class="query-section-title">
                        <sl-icon name="code"></sl-icon>
                        Query JSON (Preview)
                    </div>
                    <sl-textarea id="dslQueryPreview" class="query-editor" readonly></sl-textarea>
                </div>
                
                <sl-button variant="primary" size="large" onclick="executeDslQuery()">
                    <sl-icon slot="prefix" name="play"></sl-icon>
                    Execute Join Query
                </sl-button>
            </div>
        </sl-card>
        
        <div class="results-section">
            <sl-card>
                <div slot="header">
                    <strong>Query Results</strong>
                    <span id="dslResultCount" style="margin-left: 10px; font-weight: normal;"></span>
                </div>
                <div id="dslResults">
                    <p style="color: #666;">Execute a query to see results in a resizable table...</p>
                </div>
            </sl-card>
        </div>
    </div>

    <!-- Saved Queries Panel -->
    <div id="saved-panel" class="tab-panel">
        <sl-card>
            <div slot="header">
                <strong>Saved Queries</strong>
                <span style="margin-left: 10px; color: #666; font-size: 14px;">Manage and execute saved queries</span>
            </div>
            
            <!-- Save New Query Form -->
            <div class="saved-query-form" id="saveQueryForm" style="display: none;">
                <h3>Save Current Query</h3>
                <div class="input-group">
                    <label>Query Name:</label>
                    <sl-input id="saveQueryName" placeholder="e.g., GMC-Shopify Join All Fields" size="medium"></sl-input>
                </div>
                <div class="input-group">
                    <label>Description (optional):</label>
                    <sl-input id="saveQueryDesc" placeholder="Brief description of what this query does..." size="medium"></sl-input>
                </div>
                <div style="display: flex; gap: 10px;">
                    <sl-button variant="primary" onclick="saveCurrentQuery()">Save Query</sl-button>
                    <sl-button variant="neutral" onclick="hideSaveQueryForm()">Cancel</sl-button>
                </div>
            </div>
            
            <!-- Predefined Queries Section -->
            <div style="margin-bottom: 20px;">
                <h3>Predefined Queries</h3>
                <div id="predefinedQueries">
                    <!-- Predefined queries will be loaded here -->
                </div>
            </div>
            
            <!-- User Saved Queries -->
            <div>
                <h3>Your Saved Queries</h3>
                <div id="savedQueriesList">
                    <p style="color: #666;">No saved queries yet. Build a query in the Advanced tab and save it!</p>
                </div>
            </div>
        </sl-card>
        
        <!-- Saved Query Results -->
        <div class="results-section" id="savedQueryResults" style="display: none;">
            <sl-card>
                <div slot="header">
                    <strong>Saved Query Results</strong>
                    <span id="savedResultCount" style="margin-left: 10px; font-weight: normal;"></span>
                    <sl-button slot="header-actions" variant="neutral" size="small" onclick="exportToCSV()">
                        <sl-icon slot="prefix" name="download"></sl-icon>
                        Export CSV
                    </sl-button>
                </div>
                <div id="savedResultsContainer">
                    <p style="color: #666;">Execute a saved query to see results...</p>
                </div>
            </sl-card>
        </div>
    </div>

    <script>
        const API_BASE = window.location.origin;
        let availableFiles = [];
        let currentQueryResult = null; // Store last result for export

        // Tab switching
        function showTab(tabName) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(tabName + '-panel').classList.add('active');
            
            if (tabName === 'saved') {
                loadSavedQueriesList();
                loadPredefinedQueries();
            }
        }

        async function apiCall(endpoint, method = 'GET', body = null) {
            try {
                const options = {
                    method,
                    headers: {
                        'Content-Type': 'application/json',
                    }
                };

                if (body) {
                    options.body = JSON.stringify(body);
                }

                const response = await fetch(`${API_BASE}${endpoint}`, options);

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                return await response.json();
            } catch (error) {
                console.error('API Error:', error);
                throw error;
            }
        }

        async function loadJsonFiles() {
            const loadResult = document.getElementById('loadResult');
            loadResult.innerHTML = '<sl-spinner></sl-spinner> Loading JSON files...';

            try {
                const result = await apiCall('/load', 'POST');

                let message = `<div class="success-message">Loaded ${result.total_objects} objects from ${result.loaded_files.length} files!</div>`;

                if (result.errors.length > 0) {
                    message += `<div class="error-message"><strong>Errors encountered:</strong><br>` +
                        result.errors.join('<br>') + '</div>';
                }

                loadResult.innerHTML = message;

                await loadStats();
                await loadFiles();
            } catch (error) {
                loadResult.innerHTML = `<div class="error-message">Error loading files: ${error.message}</div>`;
            }
        }

        async function loadStats() {
            try {
                const stats = await apiCall('/stats');
                document.getElementById('totalObjects').textContent = stats.total_objects;
                document.getElementById('totalFiles').textContent = stats.total_files;
            } catch (error) {
                console.error('Error loading stats:', error);
            }
        }

        async function loadFiles() {
            try {
                const files = await apiCall('/files');
                availableFiles = files;
                
                // Update simple query select
                const select = document.getElementById('sourceFile');
                select.innerHTML = '<sl-option value="">All Files</sl-option>';

                files.forEach(file => {
                    const option = document.createElement('sl-option');
                    option.value = file;
                    option.textContent = file;
                    select.appendChild(option);
                });
                
                // Update DSL query selects
                const dslFrom = document.getElementById('dslFromSource');
                dslFrom.innerHTML = '<sl-option value="">Select a file...</sl-option>';
                files.forEach(file => {
                    const option = document.createElement('sl-option');
                    option.value = file;
                    option.textContent = file;
                    dslFrom.appendChild(option);
                });
            } catch (error) {
                console.error('Error loading files:', error);
            }
        }

        async function executeQuery() {
            const filter = document.getElementById('filter').value;
            const sourceFile = document.getElementById('sourceFile').value || null;
            const limit = parseInt(document.getElementById('limit').value) || 50;

            const params = new URLSearchParams();
            if (filter) params.append('filter', filter);
            if (sourceFile) params.append('source_file', sourceFile);
            params.append('limit', limit);

            const resultsDiv = document.getElementById('results');
            resultsDiv.innerHTML = '<sl-spinner></sl-spinner> Executing query...';

            try {
                const objects = await apiCall(`/query?${params.toString()}`);
                displayResults(objects);
            } catch (error) {
                resultsDiv.innerHTML = `<div class="error-message">Query error: ${error.message}</div>`;
            }
        }

        function displayResults(objects) {
            const resultsDiv = document.getElementById('results');
            const resultCount = document.getElementById('resultCount');

            resultCount.textContent = `(Found ${objects.length} objects)`;

            if (objects.length === 0) {
                resultsDiv.innerHTML = '<p style="color: #666;">No objects found matching your query.</p>';
                return;
            }

            let html = '';
            objects.forEach(obj => {
                const jsonData = JSON.parse(obj.json_data);
                html += `
                    <div class="object-item">
                        <div class="object-header">
                            <strong>ID: ${obj.id}</strong>
                            <sl-tag size="small">${obj.source_file}</sl-tag>
                        </div>
                        <div class="file-info">
                            <sl-icon name="file-earmark"></sl-icon>
                            <small>Modified: ${new Date(parseInt(obj.modified_at) * 1000).toLocaleString()}</small>
                        </div>
                        <div class="object-content">
                            <pre>${JSON.stringify(jsonData, null, 2)}</pre>
                        </div>
                    </div>
                `;
            });

            resultsDiv.innerHTML = html;
        }

        function setFilter(filter) {
            document.getElementById('filter').value = filter;
        }

        // DSL Query Builder Functions
        let joinCount = 0;
        let whereCount = 0;
        let selectCount = 0;

        function addJoin() {
            joinCount++;
            const container = document.getElementById('joinsContainer');
            const joinDiv = document.createElement('div');
            joinDiv.className = 'join-builder';
            joinDiv.id = `join-${joinCount}`;
            
            const fileOptions = availableFiles.map(f => `<sl-option value="${f}">${f}</sl-option>`).join('');
            
            joinDiv.innerHTML = `
                <div class="field-row">
                    <sl-select id="joinSource-${joinCount}" placeholder="Join source file" size="medium">
                        ${fileOptions}
                    </sl-select>
                    <sl-input id="joinAlias-${joinCount}" placeholder="Alias" size="medium" value="join${joinCount}"></sl-input>
                    <sl-select id="joinType-${joinCount}" value="inner" size="medium" style="width: 120px;">
                        <sl-option value="inner">Inner</sl-option>
                        <sl-option value="left">Left</sl-option>
                    </sl-select>
                    <sl-icon-button name="x-lg" class="remove-btn" onclick="removeJoin(${joinCount})"></sl-icon-button>
                </div>
                <div class="field-row">
                    <sl-input id="joinLeft-${joinCount}" placeholder="Left field (e.g., primary.mpn)" size="medium"></sl-input>
                    <span style="padding-bottom: 8px;">=</span>
                    <sl-input id="joinRight-${joinCount}" placeholder="Right field (e.g., join1.variants[].sku)" size="medium"></sl-input>
                </div>
            `;
            container.appendChild(joinDiv);
            updateQueryPreview();
        }

        function removeJoin(id) {
            const joinDiv = document.getElementById(`join-${id}`);
            if (joinDiv) joinDiv.remove();
            updateQueryPreview();
        }

        function addWhere() {
            whereCount++;
            const container = document.getElementById('whereContainer');
            const whereDiv = document.createElement('div');
            whereDiv.className = 'field-row';
            whereDiv.id = `where-${whereCount}`;
            whereDiv.innerHTML = `
                <sl-input id="whereField-${whereCount}" placeholder="Field (e.g., join1.status)" size="medium"></sl-input>
                <sl-select id="whereOp-${whereCount}" value="=" size="medium" style="width: 140px;">
                    <sl-option value="=">=</sl-option>
                    <sl-option value="!=">!=</sl-option>
                    <sl-option value="contains">contains</sl-option>
                    <sl-option value="starts_with">starts_with</sl-option>
                    <sl-option value="exists">exists</sl-option>
                </sl-select>
                <sl-input id="whereValue-${whereCount}" placeholder="Value" size="medium"></sl-input>
                <sl-icon-button name="x-lg" class="remove-btn" onclick="removeWhere(${whereCount})"></sl-icon-button>
            `;
            container.appendChild(whereDiv);
            updateQueryPreview();
        }

        function removeWhere(id) {
            const whereDiv = document.getElementById(`where-${id}`);
            if (whereDiv) whereDiv.remove();
            updateQueryPreview();
        }

        function addSelectField() {
            selectCount++;
            const container = document.getElementById('selectContainer');
            const selectDiv = document.createElement('div');
            selectDiv.className = 'field-row';
            selectDiv.id = `select-${selectCount}`;
            selectDiv.innerHTML = `
                <sl-input id="selectExpr-${selectCount}" placeholder="Field expression (e.g., primary.title)" size="medium"></sl-input>
                <sl-input id="selectAlias-${selectCount}" placeholder="Output column name" size="medium"></sl-input>
                <sl-select id="selectTransform-${selectCount}" placeholder="Transform" clearable size="medium" style="width: 120px;">
                    <sl-option value="">None</sl-option>
                    <sl-option value="upper">UPPERCASE</sl-option>
                    <sl-option value="lower">lowercase</sl-option>
                </sl-select>
                <sl-icon-button name="x-lg" class="remove-btn" onclick="removeSelectField(${selectCount})"></sl-icon-button>
            `;
            container.appendChild(selectDiv);
            updateQueryPreview();
        }

        function removeSelectField(id) {
            const selectDiv = document.getElementById(`select-${id}`);
            if (selectDiv) selectDiv.remove();
            updateQueryPreview();
        }

        function buildQuery() {
            const fromSource = document.getElementById('dslFromSource').value;
            const fromAlias = document.getElementById('dslFromAlias').value || 'primary';
            
            if (!fromSource) return null;
            
            const query = {
                from: {
                    source_file: fromSource,
                    alias: fromAlias
                },
                joins: [],
                where: [],
                select: [],
                flatten: document.getElementById('dslFlatten').checked,
                limit: parseInt(document.getElementById('dslLimit').value) || 100
            };
            
            // Build joins
            for (let i = 1; i <= joinCount; i++) {
                const joinDiv = document.getElementById(`join-${i}`);
                if (!joinDiv) continue;
                
                const source = document.getElementById(`joinSource-${i}`).value;
                const alias = document.getElementById(`joinAlias-${i}`).value;
                const joinType = document.getElementById(`joinType-${i}`).value;
                const left = document.getElementById(`joinLeft-${i}`).value;
                const right = document.getElementById(`joinRight-${i}`).value;
                
                if (source && left && right) {
                    query.joins.push({
                        source: { source_file: source, alias: alias },
                        on: { left, right },
                        join_type: joinType
                    });
                }
            }
            
            // Build where
            for (let i = 1; i <= whereCount; i++) {
                const whereDiv = document.getElementById(`where-${i}`);
                if (!whereDiv) continue;
                
                const field = document.getElementById(`whereField-${i}`).value;
                const op = document.getElementById(`whereOp-${i}`).value;
                let value = document.getElementById(`whereValue-${i}`).value;
                
                if (field) {
                    // Try to parse as number if possible
                    if (!isNaN(value) && value !== '') {
                        value = parseFloat(value);
                    }
                    query.where.push({ field, op, value });
                }
            }
            
            // Build select
            for (let i = 1; i <= selectCount; i++) {
                const selectDiv = document.getElementById(`select-${i}`);
                if (!selectDiv) continue;
                
                const expr = document.getElementById(`selectExpr-${i}`).value;
                const alias = document.getElementById(`selectAlias-${i}`).value;
                const transform = document.getElementById(`selectTransform-${i}`).value;
                
                if (expr) {
                    const field = { expr };
                    if (alias) field.alias = alias;
                    if (transform) field.transform = transform;
                    query.select.push(field);
                }
            }
            
            return query;
        }

        function updateQueryPreview() {
            const query = buildQuery();
            if (query) {
                document.getElementById('dslQueryPreview').value = JSON.stringify(query, null, 2);
            }
        }

        async function executeDslQuery() {
            const query = buildQuery();
            if (!query) {
                alert('Please select a primary source file');
                return;
            }
            
            const resultsDiv = document.getElementById('dslResults');
            resultsDiv.innerHTML = '<sl-spinner></sl-spinner> Executing query...';

            try {
                const response = await apiCall('/query/dsl', 'POST', { query: JSON.stringify(query) });
                
                if (response.success) {
                    displayDslResults(response);
                } else {
                    resultsDiv.innerHTML = `<div class="error-message">Query error: ${response.error}</div>`;
                }
            } catch (error) {
                resultsDiv.innerHTML = `<div class="error-message">Error: ${error.message}</div>`;
            }
        }

        function displayDslResults(result) {
            const resultsDiv = document.getElementById('dslResults');
            const resultCount = document.getElementById('dslResultCount');
            
            resultCount.textContent = `(Found ${result.total_count} rows, showing ${result.rows.length})`;
            
            if (result.rows.length === 0) {
                resultsDiv.innerHTML = '<p style="color: #666;">No results found.</p>';
                return;
            }
            
            // Build resizable table
            let html = '<div class="table-container"><table class="result-table"><thead><tr>';
            
            // Headers
            result.columns.forEach(col => {
                html += `<th>${col}</th>`;
            });
            html += '</tr></thead><tbody>';
            
            // Rows
            result.rows.forEach(row => {
                html += '<tr>';
                row.forEach(cell => {
                    let displayValue;
                    if (cell === null) {
                        displayValue = '<span class="null-value">null</span>';
                    } else if (typeof cell === 'object') {
                        displayValue = JSON.stringify(cell);
                    } else {
                        displayValue = String(cell);
                    }
                    html += `<td title="${displayValue.replace(/"/g, '&quot;')}">${displayValue}</td>`;
                });
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            resultsDiv.innerHTML = html;
        }

        // Saved Queries Functions
        const PREDEFINED_QUERIES = [
            {
                id: 'gmc-shopify-full',
                name: 'GMC-Shopify Full Join',
                description: 'Joins GMC and Shopify products matching MPN to SKU, returns all common fields',
                query: {
                    from: { source_file: "gmc_zucker_products.json", alias: "primary" },
                    joins: [{
                        source: { source_file: "shopify_zucker_products.json", alias: "join1" },
                        on: { left: "primary.mpn", right: "join1.variants[].sku" },
                        join_type: "inner"
                    }],
                    where: [{ field: "primary.mpn", op: "!=", value: "" }],
                    select: [
                        { expr: "primary.offerId", alias: "gmc_offerId" },
                        { expr: "primary.variantId", alias: "gmc_variantId" },
                        { expr: "primary.title", alias: "gmc_title" },
                        { expr: "primary.mpn", alias: "gmc_mpn" },
                        { expr: "primary.gtin", alias: "gmc_gtin" },
                        { expr: "primary.imageLink", alias: "gmc_imageLink" },
                        { expr: "join1.id", alias: "shopify_id" },
                        { expr: "join1.handle", alias: "shopify_handle" },
                        { expr: "join1.title", alias: "shopify_title" },
                        { expr: "join1.status", alias: "shopify_status" },
                        { expr: "join1.vendor", alias: "shopify_vendor" },
                        { expr: "join1.productType", alias: "shopify_productType" },
                        { expr: "join1.createdAt", alias: "shopify_createdAt" },
                        { expr: "join1.updatedAt", alias: "shopify_updatedAt" },
                        { expr: "join1.variants.sku", alias: "shopify_sku" },
                        { expr: "join1.variants.barcode", alias: "shopify_barcode" },
                        { expr: "join1.variants.price", alias: "shopify_price" },
                        { expr: "join1.variants.inventoryQuantity", alias: "shopify_inventory" }
                    ],
                    flatten: false,
                    limit: 10000
                }
            },
            {
                id: 'gmc-shopify-active',
                name: 'Active Products Only',
                description: 'Join with filter for ACTIVE status only',
                query: {
                    from: { source_file: "gmc_zucker_products.json", alias: "primary" },
                    joins: [{
                        source: { source_file: "shopify_zucker_products.json", alias: "join1" },
                        on: { left: "primary.mpn", right: "join1.variants[].sku" },
                        join_type: "inner"
                    }],
                    where: [
                        { field: "primary.mpn", op: "!=", value: "" },
                        { field: "join1.status", op: "=", value: "ACTIVE" }
                    ],
                    select: [
                        { expr: "primary.title", alias: "Title" },
                        { expr: "primary.mpn", alias: "MPN" },
                        { expr: "join1.variants.barcode", alias: "Barcode" },
                        { expr: "join1.variants.price", alias: "Price" },
                        { expr: "join1.status", alias: "Status" }
                    ],
                    flatten: false,
                    limit: 100
                }
            }
        ];

        function loadPredefinedQueries() {
            const container = document.getElementById('predefinedQueries');
            container.innerHTML = PREDEFINED_QUERIES.map(q => `
                <div class="saved-query-item">
                    <div class="saved-query-info">
                        <div class="saved-query-name">${q.name}</div>
                        <div class="saved-query-desc">${q.description}</div>
                    </div>
                    <div class="saved-query-actions">
                        <sl-button variant="primary" size="small" onclick="executeSavedQuery('${q.id}', true)">
                            <sl-icon slot="prefix" name="play"></sl-icon>
                            Run
                        </sl-button>
                        <sl-button variant="neutral" size="small" onclick="loadQueryToBuilder('${q.id}', true)">
                            <sl-icon slot="prefix" name="pencil"></sl-icon>
                            Edit
                        </sl-button>
                    </div>
                </div>
            `).join('');
        }

        function loadSavedQueriesList() {
            const saved = JSON.parse(localStorage.getItem('jaqSavedQueries') || '[]');
            const container = document.getElementById('savedQueriesList');
            
            if (saved.length === 0) {
                container.innerHTML = '<p style="color: #666;">No saved queries yet. Build a query in the Advanced tab and save it!</p>';
                return;
            }
            
            container.innerHTML = saved.map((q, index) => `
                <div class="saved-query-item">
                    <div class="saved-query-info">
                        <div class="saved-query-name">${q.name}</div>
                        <div class="saved-query-desc">${q.description || 'No description'} • Saved ${new Date(q.savedAt).toLocaleDateString()}</div>
                    </div>
                    <div class="saved-query-actions">
                        <sl-button variant="primary" size="small" onclick="executeSavedQuery(${index}, false)">
                            <sl-icon slot="prefix" name="play"></sl-icon>
                            Run
                        </sl-button>
                        <sl-button variant="neutral" size="small" onclick="loadQueryToBuilder(${index}, false)">
                            <sl-icon slot="prefix" name="pencil"></sl-icon>
                            Edit
                        </sl-button>
                        <sl-button variant="danger" size="small" onclick="deleteSavedQuery(${index})">
                            <sl-icon slot="prefix" name="trash"></sl-icon>
                        </sl-button>
                    </div>
                </div>
            `).join('');
        }

        function showSaveQueryDialog() {
            const query = buildQuery();
            if (!query) {
                alert('Please build a query first');
                return;
            }
            document.getElementById('saveQueryForm').style.display = 'block';
        }

        function hideSaveQueryForm() {
            document.getElementById('saveQueryForm').style.display = 'none';
            document.getElementById('saveQueryName').value = '';
            document.getElementById('saveQueryDesc').value = '';
        }

        function saveCurrentQuery() {
            const name = document.getElementById('saveQueryName').value.trim();
            if (!name) {
                alert('Please enter a query name');
                return;
            }
            
            const query = buildQuery();
            const savedQuery = {
                name: name,
                description: document.getElementById('saveQueryDesc').value,
                query: query,
                savedAt: new Date().toISOString()
            };
            
            const saved = JSON.parse(localStorage.getItem('jaqSavedQueries') || '[]');
            saved.push(savedQuery);
            localStorage.setItem('jaqSavedQueries', JSON.stringify(saved));
            
            hideSaveQueryForm();
            alert('Query saved!');
        }

        function deleteSavedQuery(index) {
            if (!confirm('Are you sure you want to delete this saved query?')) return;
            
            const saved = JSON.parse(localStorage.getItem('jaqSavedQueries') || '[]');
            saved.splice(index, 1);
            localStorage.setItem('jaqSavedQueries', JSON.stringify(saved));
            loadSavedQueriesList();
        }

        async function executeSavedQuery(idOrIndex, isPredefined) {
            let query;
            if (isPredefined) {
                const predefined = PREDEFINED_QUERIES.find(q => q.id === idOrIndex);
                query = predefined?.query;
            } else {
                const saved = JSON.parse(localStorage.getItem('jaqSavedQueries') || '[]');
                query = saved[idOrIndex]?.query;
            }
            
            if (!query) {
                alert('Query not found');
                return;
            }
            
            // Show results panel
            document.getElementById('savedQueryResults').style.display = 'block';
            const container = document.getElementById('savedResultsContainer');
            container.innerHTML = '<sl-spinner></sl-spinner> Executing query...';
            
            try {
                const response = await apiCall('/query/dsl', 'POST', { query: JSON.stringify(query) });
                
                if (response.success) {
                    currentQueryResult = response; // Store for export
                    displaySavedQueryResults(response);
                } else {
                    container.innerHTML = `<div class="error-message">Query error: ${response.error}</div>`;
                }
            } catch (error) {
                container.innerHTML = `<div class="error-message">Error: ${error.message}</div>`;
            }
        }

        function displaySavedQueryResults(result) {
            const container = document.getElementById('savedResultsContainer');
            const resultCount = document.getElementById('savedResultCount');
            
            resultCount.textContent = `(Found ${result.total_count} rows, showing ${result.rows.length})`;
            
            if (result.rows.length === 0) {
                container.innerHTML = '<p style="color: #666;">No results found.</p>';
                return;
            }
            
            let html = '<div class="table-container"><table class="result-table"><thead><tr>';
            result.columns.forEach(col => {
                html += `<th>${col}</th>`;
            });
            html += '</tr></thead><tbody>';
            
            result.rows.forEach(row => {
                html += '<tr>';
                row.forEach(cell => {
                    let displayValue;
                    if (cell === null) {
                        displayValue = '<span class="null-value">null</span>';
                    } else if (typeof cell === 'object') {
                        displayValue = JSON.stringify(cell);
                    } else {
                        displayValue = String(cell);
                    }
                    html += `<td title="${displayValue.replace(/"/g, '&quot;')}">${displayValue}</td>`;
                });
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            container.innerHTML = html;
        }

        function loadQueryToBuilder(idOrIndex, isPredefined) {
            let query;
            if (isPredefined) {
                const predefined = PREDEFINED_QUERIES.find(q => q.id === idOrIndex);
                query = predefined?.query;
            } else {
                const saved = JSON.parse(localStorage.getItem('jaqSavedQueries') || '[]');
                query = saved[idOrIndex]?.query;
            }
            
            if (!query) {
                alert('Query not found');
                return;
            }
            
            // Switch to advanced tab
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
            document.querySelector('.tab-btn:nth-child(2)').classList.add('active');
            document.getElementById('advanced-panel').classList.add('active');
            
            // Populate FROM
            document.getElementById('dslFromSource').value = query.from.source_file;
            document.getElementById('dslFromAlias').value = query.from.alias || 'primary';
            
            // Clear and populate JOINs
            document.getElementById('joinsContainer').innerHTML = '';
            joinCount = 0;
            if (query.joins) {
                query.joins.forEach(j => {
                    addJoin();
                    document.getElementById(`joinSource-${joinCount}`).value = j.source.source_file;
                    document.getElementById(`joinAlias-${joinCount}`).value = j.source.alias;
                    document.getElementById(`joinType-${joinCount}`).value = j.join_type;
                    document.getElementById(`joinLeft-${joinCount}`).value = j.on.left;
                    document.getElementById(`joinRight-${joinCount}`).value = j.on.right;
                });
            }
            
            // Clear and populate WHERE
            document.getElementById('whereContainer').innerHTML = '';
            whereCount = 0;
            if (query.where) {
                query.where.forEach(w => {
                    addWhere();
                    document.getElementById(`whereField-${whereCount}`).value = w.field;
                    document.getElementById(`whereOp-${whereCount}`).value = w.op;
                    document.getElementById(`whereValue-${whereCount}`).value = w.value;
                });
            }
            
            // Clear and populate SELECT
            document.getElementById('selectContainer').innerHTML = '';
            selectCount = 0;
            if (query.select) {
                query.select.forEach(s => {
                    addSelectField();
                    document.getElementById(`selectExpr-${selectCount}`).value = s.expr;
                    document.getElementById(`selectAlias-${selectCount}`).value = s.alias || '';
                    document.getElementById(`selectTransform-${selectCount}`).value = s.transform || '';
                });
            }
            
            // Populate options
            document.getElementById('dslFlatten').checked = query.flatten || false;
            document.getElementById('dslLimit').value = query.limit || 100;
            
            updateQueryPreview();
        }

        function exportToCSV() {
            if (!currentQueryResult || !currentQueryResult.rows) {
                alert('No data to export');
                return;
            }
            
            const { columns, rows } = currentQueryResult;
            
            // Build CSV
            let csv = columns.join(',') + '\n';
            rows.forEach(row => {
                const values = row.map(cell => {
                    if (cell === null) return '';
                    const str = typeof cell === 'object' ? JSON.stringify(cell) : String(cell);
                    // Escape quotes and wrap in quotes if contains comma
                    if (str.includes(',') || str.includes('"') || str.includes('\n')) {
                        return '"' + str.replace(/"/g, '""') + '"';
                    }
                    return str;
                });
                csv += values.join(',') + '\n';
            });
            
            // Download
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `jaq_query_results_${new Date().toISOString().slice(0,10)}.csv`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }

        // Update query preview on input changes
        document.addEventListener('input', function(e) {
            if (e.target.id && (e.target.id.startsWith('dsl') || e.target.id.startsWith('join') || 
                e.target.id.startsWith('where') || e.target.id.startsWith('select'))) {
                updateQueryPreview();
            }
        });

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', async () => {
            await loadStats();
            await loadFiles();
            
            // Add some default example fields
            addSelectField();
            document.getElementById('selectExpr-1').value = 'primary.title';
            document.getElementById('selectAlias-1').value = 'Title';
            
            addSelectField();
            document.getElementById('selectExpr-2').value = 'primary.mpn';
            document.getElementById('selectAlias-2').value = 'MPN';
        });
    </script>
</body>
</html>
